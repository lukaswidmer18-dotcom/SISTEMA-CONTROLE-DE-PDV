# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
backend/dist/
frontend/dist/

# Database (SQLite local file — seed instead)
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/*.db
backend/prisma/*.db-journal

# Uploads (user-generated content, not source code)
backend/uploads/

# Environment variables (contain secrets)
backend/.env
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude agent config (internal tooling)
.agent/

# Binary/media assets not part of source code
*.pdf

# IDE
.vscode/
.idea/

# TypeScript cache
*.tsbuildinfo
