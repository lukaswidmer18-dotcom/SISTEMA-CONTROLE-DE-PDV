# Copie para .env e preencha antes de rodar `docker compose up`.
# .env não é versionado (contém segredo).

POSTGRES_USER=pdv
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=pdv

# Gere um valor forte, ex: openssl rand -base64 32
JWT_SECRET=troque-este-segredo

# URL pública do frontend, usada pelo backend para liberar CORS
FRONTEND_URL=http://localhost:8080

# Porta exposta do frontend no host
FRONTEND_PORT=8080

# Porta exposta do Postgres no host (só pra acesso local/psql/Prisma Studio,
# a app usa a rede interna do compose). Ajuste se 5432/5434 já estiver em uso
# por outro projeto na sua máquina.
POSTGRES_PORT=5434
