generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          String   @default("PROMOTOR")
  active        Boolean  @default(true)
  monthlySalary Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pontos       Ponto[]
  visits       Visit[]
  rotas        RotaVisita[]
  ratingsGiven VisitRating[] @relation("RatedBy")

  @@map("users")
}

model PDV {
  id           String   @id @default(uuid())
  name         String
  address      String   @default("")
  city         String   @default("")
  state        String   @default("")
  latitude     Float?
  longitude    Float?
  radiusMeters Int?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  visits   Visit[]
  rotas    RotaVisita[]
  products Product[]

  @@map("pdvs")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  brand     String   @default("")
  sku       String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  validities  Validity[]
  pdvs        PDV[]
  rupturas    RupturaRegistro[]
  priceChecks PriceCheck[]

  @@map("products")
}

model Ponto {
  id                String   @id @default(uuid())
  userId            String
  visitId           String?
  type              String
  timestamp         DateTime @default(now())
  latitude          Float?
  longitude         Float?
  locationAvailable Boolean  @default(false)
  batteryLevel      Int?
  createdAt         DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  visit Visit? @relation(fields: [visitId], references: [id])

  @@map("pontos")
}

model Visit {
  id               String    @id @default(uuid())
  promotorId       String
  pdvId            String
  status           String    @default("IN_PROGRESS")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  noProductsFound  Boolean   @default(false)
  latitudeStart    Float?
  longitudeStart   Float?
  latitudeEnd      Float?
  longitudeEnd     Float?
  boxesGenerated   Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  promotor    User              @relation(fields: [promotorId], references: [id])
  pdv         PDV               @relation(fields: [pdvId], references: [id])
  photos      Photo[]
  validities  Validity[]
  pontos      Ponto[]
  rating      VisitRating?
  rupturas    RupturaRegistro[]
  priceChecks PriceCheck[]

  @@map("visits")
}

model VisitRating {
  id        String   @id @default(uuid())
  visitId   String   @unique
  score     Float
  ratedById String
  ratedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visit   Visit @relation(fields: [visitId], references: [id])
  ratedBy User  @relation("RatedBy", fields: [ratedById], references: [id])

  @@map("visit_ratings")
}

model Photo {
  id              String   @id @default(uuid())
  visitId         String
  checklistItemId String?
  filePath        String
  fileName        String
  latitude        Float?
  longitude       Float?
  uploadedAt      DateTime @default(now())

  visit         Visit          @relation(fields: [visitId], references: [id])
  checklistItem ChecklistItem? @relation(fields: [checklistItemId], references: [id])

  @@map("photos")
}

model ChecklistItem {
  id            String   @id @default(uuid())
  label         String
  order         Int      @default(0)
  requiredCount Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  photos Photo[]

  @@map("checklist_items")
}

model RotaVisita {
  id            String    @id @default(uuid())
  promotorId    String
  pdvId         String
  date          DateTime
  order         Int       @default(0)
  justification String?
  justifiedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  promotor User @relation(fields: [promotorId], references: [id])
  pdv      PDV  @relation(fields: [pdvId], references: [id])

  @@unique([promotorId, pdvId, date])
  @@map("rotas_visita")
}

model RupturaRegistro {
  id               String   @id @default(uuid())
  visitId          String
  productId        String
  qtyGondola       Int      @default(0)
  qtyDeposito      Int      @default(0)
  qtySeparadoTroca Int      @default(0)
  createdAt        DateTime @default(now())

  visit   Visit   @relation(fields: [visitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([visitId, productId])
  @@map("ruptura_registros")
}

model DegustacaoSolicitacao {
  id                   String   @id @default(uuid())
  requesterName        String
  date                 DateTime
  city                 String
  address              String
  store                String
  productEvent         String
  eventTime            String
  supervisor           String   @default("")
  justification        String   @default("")
  documentPath         String?
  documentFileName     String?
  documentOriginalName String?
  status               String   @default("pendente")
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime @default(now())

  @@map("degustacao_solicitacoes")
}

model PriceCheck {
  id              String   @id @default(uuid())
  visitId         String
  productId       String
  ownPrice        Float
  competitorName  String?
  competitorPrice Float?
  photoPath       String?
  photoFileName   String?
  createdAt       DateTime @default(now())

  visit   Visit   @relation(fields: [visitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([visitId, productId])
  @@map("price_checks")
}

model Validity {
  id         String   @id @default(uuid())
  visitId    String
  productId  String
  expiryDate String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  visit   Visit   @relation(fields: [visitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("validities")
}
